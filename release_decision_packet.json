{
  "schema_version": 1,
  "artifact": "agentic-drug-discovery-system",
  "release_version": "0.2.0",
  "decision_status": "public_released_after_human_approval",
  "as_of_date": "2026-07-14",
  "human_readable_checklist": "docs/public_launch_checklist.md",
  "surfaces": {
    "github": {
      "url": "https://github.com/jang1563/agentic-drug-discovery-system",
      "current_visibility": "public",
      "default_branch": "main",
      "release_state": "merged_to_default_branch",
      "release_pull_request": "https://github.com/jang1563/agentic-drug-discovery-system/pull/7",
      "publication_target": "public"
    },
    "hugging_face": {
      "url": "https://huggingface.co/datasets/jang1563/agentic-drug-discovery-system",
      "repo_type": "dataset",
      "current_visibility": "public",
      "publication_target": "public"
    }
  },
  "launch_decision": {
    "default": "published_after_approval",
    "human_approval_required": true,
    "no_public_visibility_change_without_explicit_approval": true,
    "approval_record": "Explicit owner approval received on 2026-07-12 to remediate and publish the GitHub and Hugging Face surfaces"
  },
  "release_scope": {
    "include": [
      "reader-facing README and project brief",
      "release boundary and launch checklist",
      "machine-readable release manifests",
      "citation and archive metadata",
      "schemas, verifier contracts, adapters, and flow scaffolds",
      "audited SCD and target-identification aggregate results cards",
      "machine-readable aggregate evidence summary",
      "benchmark/ scorer and tests for the separately hosted clinical-trial decision dataset",
      "audit scripts and GitHub Actions release audit"
    ],
    "exclude": [
      "raw source snapshots",
      "hidden or evaluator-only labels",
      "locked episode records",
      "generated reward or verifier outputs",
      "run logs",
      "credentials and key material",
      "machine-local paths",
      "model weights"
    ]
  },
  "required_checks": [
    {
      "name": "github_release_file_audit",
      "command": "python3 scripts/audit/github_release_file_audit.py",
      "blocking": true
    },
    {
      "name": "hf_release_package_validation",
      "command": "python3 scripts/audit/validate_hf_release_package.py",
      "blocking": true
    },
    {
      "name": "public_launch_packet_validation",
      "command": "python3 scripts/audit/validate_public_launch_packet.py",
      "blocking": true
    },
    {
      "name": "vertical_slice_doc_validation",
      "command": "python3 scripts/audit/validate_vertical_slice_doc.py",
      "blocking": true
    },
    {
      "name": "hf_release_package_build",
      "command": "python3 scripts/audit/build_hf_release_package.py --output /tmp/agentic-hf-release-package --force",
      "blocking": true
    },
    {
      "name": "hf_built_package_validation",
      "command": "python3 scripts/audit/validate_hf_release_package.py --package /tmp/agentic-hf-release-package",
      "blocking": true
    },
    {
      "name": "benchmark_tests",
      "command": "python3 -m pytest -q benchmark/tests",
      "blocking": true
    },
    {
      "name": "diff_check",
      "command": "git diff --check",
      "blocking": true
    },
    {
      "name": "python_compile",
      "command": "python3 -m compileall adapters chains benchmark/src scripts/audit",
      "blocking": true
    }
  ],
  "read_order": [
    "README.md",
    "docs/release_trust_report.md",
    "docs/12_scd_vertical_slice.md",
    "docs/13_target_id_governance_node.md",
    "docs/public_evidence_summary.json",
    "docs/public_launch_checklist.md",
    "docs/release_boundary.md",
    "release_manifest.json",
    "huggingface/README.md",
    "huggingface/release_manifest.json",
    "benchmark/"
  ],
  "hard_stop_if": [
    "any required check fails",
    "any release-surface file has unreviewed sensitive content",
    "GitHub or Hugging Face visibility changes without explicit approval",
    "the README overstates built functionality beyond the audited slice",
    "the Hugging Face mirror is stale relative to the reviewed source commit or fails exact file/hash validation",
    "Croissant metadata for the separate clinical-trial-decision-benchmark enters this Hub package"
  ]
}
