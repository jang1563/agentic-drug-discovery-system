{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jang1563/agentic-drug-discovery-system/blob/main/rl_env/specs/discovery_context_identity.schema.json",
  "title": "ADDS discovery context identity records",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "disease",
    "assay",
    "model_system"
  ],
  "properties": {
    "disease": {
      "$ref": "#/$defs/disease"
    },
    "assay": {
      "$ref": "#/$defs/assay"
    },
    "model_system": {
      "$ref": "#/$defs/modelSystem"
    }
  },
  "$defs": {
    "identifiers": {
      "type": "object",
      "minProperties": 1,
      "required": [
        "canonical"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportingEvidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disease_id",
        "name",
        "stage",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "disease_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "const": "disease_context"
        },
        "identifiers": {
          "$ref": "#/$defs/identifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    },
    "assay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assay_id",
        "name",
        "assay_type",
        "target_id",
        "disease_id",
        "organism",
        "stage",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "assay_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "assay_type": {
          "type": "string",
          "minLength": 1
        },
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "disease_id": {
          "type": "string",
          "minLength": 1
        },
        "organism": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "const": "preclinical_validation"
        },
        "identifiers": {
          "$ref": "#/$defs/identifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    },
    "modelSystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_system_id",
        "name",
        "model_type",
        "disease_id",
        "organism",
        "stage",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "model_system_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model_type": {
          "type": "string",
          "minLength": 1
        },
        "disease_id": {
          "type": "string",
          "minLength": 1
        },
        "organism": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "const": "preclinical_validation"
        },
        "identifiers": {
          "$ref": "#/$defs/identifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    }
  }
}
