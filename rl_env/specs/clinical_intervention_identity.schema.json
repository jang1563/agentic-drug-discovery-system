{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jang1563/agentic-drug-discovery-system/blob/main/rl_env/specs/clinical_intervention_identity.schema.json",
  "title": "ADDS clinical intervention identity records",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intervention",
    "trial",
    "trial_design"
  ],
  "properties": {
    "intervention": {
      "$ref": "#/$defs/intervention"
    },
    "trial": {
      "$ref": "#/$defs/trial"
    },
    "trial_design": {
      "$ref": "#/$defs/trialDesign"
    }
  },
  "$defs": {
    "supportingEvidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "interventionIdentifiers": {
      "type": "object",
      "minProperties": 1,
      "required": [
        "canonical"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "properties": {
        "canonical": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "trialIdentifiers": {
      "type": "object",
      "required": [
        "canonical",
        "clinicaltrials_gov"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "properties": {
        "canonical": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        },
        "clinicaltrials_gov": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        }
      }
    },
    "designIdentifiers": {
      "type": "object",
      "required": [
        "canonical",
        "clinicaltrials_gov"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "properties": {
        "canonical": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:design$"
        },
        "clinicaltrials_gov": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        }
      }
    },
    "armIdentifiers": {
      "type": "object",
      "required": [
        "canonical",
        "clinicaltrials_gov_group"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "properties": {
        "canonical": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:arm:[A-Za-z0-9._-]+$"
        },
        "clinicaltrials_gov_group": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "populationIdentifiers": {
      "type": "object",
      "required": [
        "canonical"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "properties": {
        "canonical": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:population:[A-Za-z0-9._-]+$"
        }
      }
    },
    "endpointIdentifiers": {
      "type": "object",
      "required": [
        "canonical",
        "clinicaltrials_gov_outcome"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "properties": {
        "canonical": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:endpoint:[A-Za-z0-9._-]+$"
        },
        "clinicaltrials_gov_outcome": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "safetyIdentifiers": {
      "type": "object",
      "required": [
        "canonical",
        "clinicaltrials_gov"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "properties": {
        "canonical": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:safety:[A-Za-z0-9._-]+$"
        },
        "clinicaltrials_gov": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        }
      }
    },
    "safetyArmIdentifiers": {
      "type": "object",
      "required": [
        "canonical",
        "clinicaltrials_gov_adverse_event_group"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "properties": {
        "canonical": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:safety:[A-Za-z0-9._-]+:arm:EG[0-9]{3,}$"
        },
        "clinicaltrials_gov_adverse_event_group": {
          "type": "string",
          "pattern": "^EG[0-9]{3,}$"
        }
      }
    },
    "textArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "intervention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intervention_id",
        "name",
        "candidate_id",
        "disease_id",
        "modality",
        "stage",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "intervention_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "disease_id": {
          "type": "string",
          "minLength": 1
        },
        "modality": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "enum": [
            "clinical_strategy",
            "regulatory_postmarket"
          ]
        },
        "identifiers": {
          "$ref": "#/$defs/interventionIdentifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    },
    "trial": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trial_id",
        "registry",
        "intervention_id",
        "disease_id",
        "stage",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "trial_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        },
        "registry": {
          "const": "ClinicalTrials.gov"
        },
        "intervention_id": {
          "type": "string",
          "minLength": 1
        },
        "disease_id": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "const": "clinical_strategy"
        },
        "identifiers": {
          "$ref": "#/$defs/trialIdentifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    },
    "trialArm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "arm_id",
        "trial_id",
        "label",
        "arm_type",
        "role",
        "stage",
        "intervention_id",
        "intervention_names",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "arm_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:arm:[A-Za-z0-9._-]+$"
        },
        "trial_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "arm_type": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "candidate",
            "comparator"
          ]
        },
        "stage": {
          "const": "clinical_strategy"
        },
        "intervention_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "intervention_names": {
          "$ref": "#/$defs/textArray"
        },
        "identifiers": {
          "$ref": "#/$defs/armIdentifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    },
    "trialPopulation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "population_id",
        "trial_id",
        "disease_id",
        "description",
        "enrollment_count",
        "enrollment_type",
        "sex",
        "minimum_age",
        "healthy_volunteers",
        "stage",
        "maximum_age",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "population_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:population:[A-Za-z0-9._-]+$"
        },
        "trial_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        },
        "disease_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "enrollment_count": {
          "type": "integer",
          "minimum": 1
        },
        "enrollment_type": {
          "type": "string",
          "minLength": 1
        },
        "sex": {
          "type": "string",
          "minLength": 1
        },
        "minimum_age": {
          "type": "string",
          "minLength": 1
        },
        "maximum_age": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "healthy_volunteers": {
          "type": "boolean"
        },
        "stage": {
          "const": "clinical_strategy"
        },
        "identifiers": {
          "$ref": "#/$defs/populationIdentifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    },
    "trialEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "endpoint_id",
        "trial_id",
        "population_id",
        "name",
        "outcome_type",
        "time_frame",
        "parameter_type",
        "unit",
        "reporting_status",
        "arm_ids",
        "stage",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "endpoint_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:endpoint:[A-Za-z0-9._-]+$"
        },
        "trial_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        },
        "population_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:population:[A-Za-z0-9._-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "outcome_type": {
          "type": "string",
          "minLength": 1
        },
        "time_frame": {
          "type": "string",
          "minLength": 1
        },
        "parameter_type": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "reporting_status": {
          "type": "string",
          "minLength": 1
        },
        "arm_ids": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^NCT[0-9]{8}:arm:[A-Za-z0-9._-]+$"
          }
        },
        "stage": {
          "const": "clinical_strategy"
        },
        "identifiers": {
          "$ref": "#/$defs/endpointIdentifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    },
    "trialSafetyArm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safety_arm_id",
        "safety_id",
        "trial_id",
        "arm_id",
        "role",
        "source_group_id",
        "source_group_title",
        "serious_num_affected",
        "serious_num_at_risk",
        "stage",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "safety_arm_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:safety:[A-Za-z0-9._-]+:arm:EG[0-9]{3,}$"
        },
        "safety_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:safety:[A-Za-z0-9._-]+$"
        },
        "trial_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        },
        "arm_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:arm:[A-Za-z0-9._-]+$"
        },
        "role": {
          "enum": [
            "candidate",
            "comparator"
          ]
        },
        "source_group_id": {
          "type": "string",
          "pattern": "^EG[0-9]{3,}$"
        },
        "source_group_title": {
          "type": "string",
          "minLength": 1
        },
        "serious_num_affected": {
          "type": "integer",
          "minimum": 0
        },
        "serious_num_at_risk": {
          "type": "integer",
          "minimum": 1
        },
        "stage": {
          "const": "clinical_strategy"
        },
        "identifiers": {
          "$ref": "#/$defs/safetyArmIdentifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    },
    "trialSafety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safety_id",
        "trial_id",
        "event_category",
        "reporting_status",
        "time_frame",
        "event_term_count",
        "arm_summaries",
        "stage",
        "description",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "safety_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:safety:[A-Za-z0-9._-]+$"
        },
        "trial_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        },
        "event_category": {
          "const": "SERIOUS"
        },
        "reporting_status": {
          "const": "POSTED"
        },
        "time_frame": {
          "type": "string",
          "minLength": 1
        },
        "event_term_count": {
          "type": "integer",
          "minimum": 0
        },
        "arm_summaries": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/trialSafetyArm"
          }
        },
        "stage": {
          "const": "clinical_strategy"
        },
        "description": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "identifiers": {
          "$ref": "#/$defs/safetyIdentifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    },
    "trialDesign": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "design_id",
        "trial_id",
        "intervention_id",
        "disease_id",
        "stage",
        "arms",
        "populations",
        "endpoints",
        "safety_records",
        "identifiers",
        "supporting_evidence",
        "attributes"
      ],
      "properties": {
        "design_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}:design$"
        },
        "trial_id": {
          "type": "string",
          "pattern": "^NCT[0-9]{8}$"
        },
        "intervention_id": {
          "type": "string",
          "minLength": 1
        },
        "disease_id": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "const": "clinical_strategy"
        },
        "arms": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/trialArm"
          }
        },
        "populations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/trialPopulation"
          }
        },
      "endpoints": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
          "$ref": "#/$defs/trialEndpoint"
        }
      },
      "safety_records": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "$ref": "#/$defs/trialSafety"
        }
      },
        "identifiers": {
          "$ref": "#/$defs/designIdentifiers"
        },
        "supporting_evidence": {
          "$ref": "#/$defs/supportingEvidence"
        },
        "attributes": {
          "type": "object"
        }
      }
    }
  }
}
