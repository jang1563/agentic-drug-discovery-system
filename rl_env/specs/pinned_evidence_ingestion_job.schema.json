{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jang1563/agentic-drug-discovery-system/blob/main/rl_env/specs/pinned_evidence_ingestion_job.schema.json",
  "title": "ADDS pinned-evidence ingestion job",
  "description": "Reviewer-authored summaries that bind to separately captured source receipts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "records"
  ],
  "properties": {
    "schema_version": {
      "const": "adds.pinned-ingestion-job.v1"
    },
    "job_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/record"
      }
    }
  },
  "$defs": {
    "publicSummaryValue": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 4096
        },
        {
          "type": [
            "number",
            "boolean",
            "null"
          ]
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/publicSummaryValue"
          }
        },
        {
          "$ref": "#/$defs/publicSummaryObject"
        }
      ]
    },
    "publicSummaryObject": {
      "type": "object",
      "propertyNames": {
        "not": {
          "pattern": "^(?:[Bb][Oo][Dd][Yy]|[Dd][Oo][Cc][Uu][Mm][Ee][Nn][Tt][^A-Za-z0-9]+[Tt][Ee][Xx][Tt]|[Ff][Uu][Ll][Ll][^A-Za-z0-9]+[Tt][Ee][Xx][Tt]|[Hh][Tt][Mm][Ll]|[Pp][Aa][Yy][Ll][Oo][Aa][Dd]|[Rr][Aa][Ww][^A-Za-z0-9]+[Pp][Aa][Yy][Ll][Oo][Aa][Dd]|[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee][^A-Za-z0-9]+[Bb][Oo][Dd][Yy]|[Ss][Oo][Uu][Rr][Cc][Ee][^A-Za-z0-9]+[Pp][Aa][Yy][Ll][Oo][Aa][Dd]|[Xx][Mm][Ll])$"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/publicSummaryValue"
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_receipt_id",
        "record_id",
        "predicate",
        "subject",
        "object_value",
        "observed_at",
        "available_at",
        "confidence",
        "biological_context",
        "metadata"
      ],
      "properties": {
        "source_receipt_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
        },
        "record_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "predicate": {
          "enum": [
            "disease_burden_supported",
            "treatment_gap_supported",
            "candidate_target_functional_activity_supported",
            "disease_model_effect_supported"
          ]
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "object_value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "observed_at": {
          "type": "string",
          "format": "date"
        },
        "available_at": {
          "type": "string",
          "format": "date"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "biological_context": {
          "$ref": "#/$defs/publicSummaryObject"
        },
        "metadata": {
          "$ref": "#/$defs/publicSummaryObject"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "predicate": {
                "const": "disease_burden_supported"
              }
            }
          },
          "then": {
            "properties": {
              "biological_context": {
                "required": [
                  "disease_id",
                  "evidence_context_id"
                ]
              },
              "metadata": {
                "required": [
                  "measure_type",
                  "measure_value",
                  "measure_unit",
                  "population",
                  "geography",
                  "reference_period"
                ],
                "properties": {
                  "measure_type": {
                    "type": "string",
                    "minLength": 1
                  },
                  "measure_value": {
                    "type": "number"
                  },
                  "measure_unit": {
                    "type": "string",
                    "minLength": 1
                  },
                  "population": {
                    "type": "string",
                    "minLength": 1
                  },
                  "geography": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reference_period": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "predicate": {
                "const": "treatment_gap_supported"
              }
            }
          },
          "then": {
            "properties": {
              "biological_context": {
                "required": [
                  "disease_id",
                  "evidence_context_id"
                ]
              },
              "metadata": {
                "required": [
                  "treatment_context",
                  "gap_summary",
                  "population",
                  "geography",
                  "reference_period"
                ],
                "properties": {
                  "treatment_context": {
                    "type": "string",
                    "minLength": 1
                  },
                  "gap_summary": {
                    "type": "string",
                    "minLength": 1
                  },
                  "population": {
                    "type": "string",
                    "minLength": 1
                  },
                  "geography": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reference_period": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "predicate": {
                "const": "candidate_target_functional_activity_supported"
              }
            }
          },
          "then": {
            "properties": {
              "biological_context": {
                "required": [
                  "candidate_id",
                  "target_id",
                  "target_record_id",
                  "disease_id",
                  "organism",
                  "assay_id"
                ]
              },
              "metadata": {
                "required": [
                  "assay_name",
                  "assay_type",
                  "source_assay_type",
                  "source_assay_type_description",
                  "functional_readout",
                  "endpoint",
                  "endpoint_relation",
                  "endpoint_value",
                  "endpoint_unit",
                  "effect_direction",
                  "candidate_aliases",
                  "source_lineage_ids"
                ],
                "properties": {
                  "assay_type": {
                    "const": "functional"
                  },
                  "source_assay_type": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source_assay_type_description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "functional_readout": {
                    "const": true
                  },
                  "endpoint_relation": {
                    "enum": ["lt", "le", "eq", "ge", "gt"]
                  },
                  "endpoint_value": {
                    "type": "number"
                  },
                  "endpoint_unit": {
                    "type": "string",
                    "minLength": 1
                  },
                  "candidate_aliases": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 32,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "source_lineage_ids": {
                    "$ref": "#/$defs/sourceLineageIds"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "predicate": {
                "const": "disease_model_effect_supported"
              }
            }
          },
          "then": {
            "properties": {
              "biological_context": {
                "required": [
                  "candidate_id",
                  "disease_id",
                  "organism",
                  "model_system_id"
                ]
              },
              "metadata": {
                "required": [
                  "model_system",
                  "model_type",
                  "endpoint",
                  "endpoint_relation",
                  "endpoint_value",
                  "endpoint_unit",
                  "effect_direction",
                  "disease_relevance",
                  "source_candidate_name",
                  "source_lineage_ids"
                ],
                "properties": {
                  "endpoint_relation": {
                    "enum": ["lt", "le", "eq", "ge", "gt"]
                  },
                  "endpoint_value": {
                    "type": "number"
                  },
                  "endpoint_unit": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source_candidate_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source_lineage_ids": {
                    "$ref": "#/$defs/sourceLineageIds"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "sourceLineageIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9._-]*:[^\\s:][^\\s]*$"
      }
    }
  }
}
