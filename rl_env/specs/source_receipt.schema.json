{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jang1563/agentic-drug-discovery-system/blob/main/rl_env/specs/source_receipt.schema.json",
  "title": "ADDS immutable source receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "source",
    "retrieved_at",
    "byte_size",
    "media_type",
    "transport"
  ],
  "properties": {
    "schema_version": {
      "const": "adds.source-receipt.v1"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_version",
        "locator",
        "content_hash"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "source_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "description": "Caller-declared immutable revision; runtime validation rejects latest, current, unknown, and unpinned markers."
        },
        "locator": {
          "type": "string",
          "pattern": "^(https://|doi:|urn:|fixture://)",
          "maxLength": 4096
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "byte_size": {
      "type": "integer",
      "minimum": 1
    },
    "media_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "transport": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "http_status"
          ],
          "properties": {
            "method": {
              "const": "https"
            },
            "http_status": {
              "const": 200
            },
            "etag": {
              "type": "string",
              "minLength": 1
            },
            "last_modified": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method"
          ],
          "properties": {
            "method": {
              "const": "local_file"
            },
            "etag": {
              "type": "string",
              "minLength": 1
            },
            "last_modified": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
